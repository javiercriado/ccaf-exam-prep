# cli_project — env vars it reads.
#
# You normally do NOT need a local .env here: it uses python-dotenv, which
# auto-discovers the .env at the REPO ROOT. Just set your key once in ../../.env.
# This file documents the vars; copy it to ".env" here only if you want a local one.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# REQUIRED — cli_project asserts this is set at startup. Cheapest model by default.
CLAUDE_MODEL=claude-haiku-4-5

# Optional — set to 1 to launch the MCP server via `uv` instead of the local venv.
# USE_UV=
