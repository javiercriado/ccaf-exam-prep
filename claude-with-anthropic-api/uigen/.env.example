# uigen (Next.js) — copy this to ".env" IN THIS FOLDER to use real generation.
#
# Unlike the Python code, Next.js reads .env from THIS project root only — it does
# NOT pick up the repo-root .env. So uigen genuinely needs its own .env here.
# Both vars below are OPTIONAL: with no key, the app runs in a built-in MOCK mode.

# Optional — set a real key for real component generation (otherwise: mock provider).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — secret used to sign auth JWTs. Falls back to a dev value if unset;
# set a real random string if you expose this beyond local use.
# JWT_SECRET=change-me-to-a-random-string

# Note: the database is local SQLite (prisma/schema.prisma -> file:./dev.db),
# so no DATABASE_URL is needed. Run `npm run setup` once after cloning.
