# queries (Node/TypeScript) — env var it needs.
#
# The Claude Agent SDK reads ANTHROPIC_API_KEY from the process environment. This
# project does NOT load .env automatically (no dotenv). So either:
#   - export it in your shell:        export ANTHROPIC_API_KEY=sk-ant-...
#   - or run with Node's env-file:    node --env-file=.env <script>
#   - or use the repo-root .env via:  node --env-file=../../.env <script>

ANTHROPIC_API_KEY=sk-ant-your-key-here
