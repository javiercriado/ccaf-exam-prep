# Copy this file to ".env" (same folder — the repo root) and add your key.
# Every notebook and exercise script auto-discovers this file by walking up the
# directory tree (python-dotenv's find_dotenv), so you do NOT configure any path.
#
# Get an API key: https://console.anthropic.com/  (Settings -> API Keys)

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — override the model used everywhere. Defaults to claude-haiku-4-5
# (the cheapest model; these demos teach mechanisms, not model IQ). Only bump this
# if a specific demo turns out flaky on Haiku.
# CLAUDE_MODEL=claude-haiku-4-5

# --- Only needed for the original Anthropic course code (claude-with-anthropic-api/) ---
# cli_project requires CLAUDE_MODEL to be SET — uncomment the line above to run it.
# The embeddings course notebook (002_embeddings.ipynb) needs a Voyage AI key:
# VOYAGE_API_KEY=pa-your-voyage-key-here
# (uigen is a Next.js app — it reads its OWN claude-with-anthropic-api/uigen/.env, not this one.)
